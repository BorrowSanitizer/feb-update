      "encoding": {"text": {"field": "t"}}
    },
    {
      "transform": [{"calculate": "'Tests Passing'", "as": "t"}],
      "mark": {"type": "text", "dy": 25, "fontSize": 24, "fill": "black"},
      "encoding": {"text": {"field": "t"}}

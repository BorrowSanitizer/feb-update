{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 250,
  "height": 200,
  "data": {"values": [{}]},
  "layer": [
    {
      "data": {
        "values": [
          {"category": "Completed", "value": 323},
          {"category": "Remaining (UB)", "value": 58},
          {"category": "Remaining (Exit 0)", "value": 24}
